# Copy this file to ".env" and fill in your bot token.
# Get a token at https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=

# Optional: a test server (guild) ID for INSTANT slash-command sync during development.
# Right-click your server -> Copy Server ID (Developer Mode must be on). Leave blank for
# global sync (can take up to an hour to appear).
DEV_GUILD_ID=

# Optional: path to the SQLite database file (defaults to r6.db in the project root).
DB_PATH=r6.db
